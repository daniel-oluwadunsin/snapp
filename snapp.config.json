{
  "project": {
    "name": "Godconnect",
    "bundleId": "com.godconnect.online",
    "platforms": {
      "ios": false,
      "android": true
    }
  },
  "runtime": {
    "timeoutMs": 50000000000000,
    "delayAfterLaunchMs": 2000
  },
  "deepLinks": {
    "prefix": {
      "android": "godconnect://",
      "ios": "godconnect://"
    }
  },
  "screens": [
    {
      "name": "Home Screen",
      "url": "/app/post",
      "waitFor": {
        "type": "timeout",
        "value": 3000
      },
      "screenshot": {
        "fileName": "home"
      }
    },
    {
      "name": "Profile Screen",
      "url": "/app/profile?userId=7788"
    }
  ],
  "output": {
    "dir": "./screenshots",
    "format": "png",
    "structure": {
      "groupByDevice": false,
      "groupByScreen": true
    }
  }
}
